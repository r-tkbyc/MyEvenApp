#compdef evenhub

autoload -U is-at-least

_evenhub() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--completion-fish[]' \
'--completion-bash[]' \
'--completion-zsh[]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_evenhub_commands" \
"*::: :->evenhub" \
&& ret=0
    case $state in
    (evenhub)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:evenhub-command-$line[1]:"
        case $line[1] in
            (login)
_arguments "${_arguments_options[@]}" : \
'-e+[Your email]:EMAIL:_default' \
'--email=[Your email]:EMAIL:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-d+[The directory to create the project in]:DIRECTORY:_default' \
'--directory=[The directory to create the project in]:DIRECTORY:_default' \
'-o+[The output file name]:OUTPUT:_default' \
'--output=[The output file name]:OUTPUT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(pack)
_arguments "${_arguments_options[@]}" : \
'-o+[The output file name]:OUTPUT:_default' \
'--output=[The output file name]:OUTPUT:_default' \
'--no-ignore[Include hidden files (starting with '\''.'\'')]' \
'-c[Check if the package id is available]' \
'--check[Check if the package id is available]' \
'-h[Print help]' \
'--help[Print help]' \
':json -- Path to app.json:_files' \
':project -- Your built folder (dist, build, ...):_files -/' \
&& ret=0
;;
(qr)
_arguments "${_arguments_options[@]}" : \
'-u+[The full url to generate a QR code for, ignore most other options if provided]:URL:_default' \
'--url=[The full url to generate a QR code for, ignore most other options if provided]:URL:_default' \
'-i+[The IP address or hostname to use for the QR code]:IP:_default' \
'--ip=[The IP address or hostname to use for the QR code]:IP:_default' \
'-p+[The port to use for the QR code]::PORT:_default' \
'--port=[The port to use for the QR code]::PORT:_default' \
'--path=[The path to use for the QR code]:PATH:_default' \
'--https[Use HTTPS instead of HTTP]' \
'--http[Use HTTP instead of HTTPS]' \
'-e[Print the QR code to the terminal instead of opening in an external program]' \
'--external[Print the QR code to the terminal instead of opening in an external program]' \
'--clear[Clear the cached IP, port and scheme]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_evenhub__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:evenhub-help-command-$line[1]:"
        case $line[1] in
            (login)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(pack)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(qr)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_evenhub_commands] )) ||
_evenhub_commands() {
    local commands; commands=(
'login:Log in to EvenHub with your account' \
'init:Initialize a project with a basic app.json file' \
'pack:Pack your project into a .ehpk file' \
'qr:Generate a QR code' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'evenhub commands' commands "$@"
}
(( $+functions[_evenhub__help_commands] )) ||
_evenhub__help_commands() {
    local commands; commands=(
'login:Log in to EvenHub with your account' \
'init:Initialize a project with a basic app.json file' \
'pack:Pack your project into a .ehpk file' \
'qr:Generate a QR code' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'evenhub help commands' commands "$@"
}
(( $+functions[_evenhub__help__help_commands] )) ||
_evenhub__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub help help commands' commands "$@"
}
(( $+functions[_evenhub__help__init_commands] )) ||
_evenhub__help__init_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub help init commands' commands "$@"
}
(( $+functions[_evenhub__help__login_commands] )) ||
_evenhub__help__login_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub help login commands' commands "$@"
}
(( $+functions[_evenhub__help__pack_commands] )) ||
_evenhub__help__pack_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub help pack commands' commands "$@"
}
(( $+functions[_evenhub__help__qr_commands] )) ||
_evenhub__help__qr_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub help qr commands' commands "$@"
}
(( $+functions[_evenhub__init_commands] )) ||
_evenhub__init_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub init commands' commands "$@"
}
(( $+functions[_evenhub__login_commands] )) ||
_evenhub__login_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub login commands' commands "$@"
}
(( $+functions[_evenhub__pack_commands] )) ||
_evenhub__pack_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub pack commands' commands "$@"
}
(( $+functions[_evenhub__qr_commands] )) ||
_evenhub__qr_commands() {
    local commands; commands=()
    _describe -t commands 'evenhub qr commands' commands "$@"
}

if [ "$funcstack[1]" = "_evenhub" ]; then
    _evenhub "$@"
else
    compdef _evenhub evenhub
fi
